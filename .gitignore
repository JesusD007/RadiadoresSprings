## ---------------------------------------------------------------
## .gitignore para RadiadoresSprings
## Solución .NET / C# / ASP.NET Core — Azure App Service
## ---------------------------------------------------------------

# ========================
# .NET / MSBuild
# ========================
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# NuGet
*.nupkg
*.nuspec
.nuget/
packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# ========================
# Visual Studio / VS Code
# ========================
.vs/
.vscode/
*.rsuser
*.VC.db
*.VC.opendb
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.VC.opendb

# Test results
TestResult.xml
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# VS Tracing
*.e2e

# ========================
# JetBrains Rider
# ========================
.idea/
*.sln.iml

# ========================
# Publicación / Deploy
# ========================
**/publish/
**/PublishProfiles/
*.pubxml
*.pubxml.user
*.publishproj

# ========================
# Secrets y configuración sensible
# ========================
appsettings.Development.json
appsettings.Local.json
secrets.json
*.pfx
*.p12
*.env
.env
.env.*
!.env.example

# ========================
# Azure Publish Profiles
# ========================
# Los perfiles .pubxml se ignoran por contener datos de conexión sensibles.
# Sólo se versiona el archivo .pubxml si no lleva credenciales embebidas.
**/PublishProfiles/*.pubxml
**/PublishProfiles/*.pubxml.user

# ========================
# Bases de datos locales (LocalDB / SQL Server)
# ========================
DataBases/**/*.mdf
DataBases/**/*.ldf
DataBases/**/*.ndf
!DataBases/**/.gitkeep
**/DataBases/**/*.mdf
**/DataBases/**/*.ldf
**/DataBases/**/*.ndf
!**/DataBases/**/.gitkeep

# ========================
# Logs y datos temporales
# ========================
*.log
*.tmp
*.temp
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ========================
# OS específico
# ========================
# Windows
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ========================
# Node.js (por si se agrega frontend a futuro)
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js

# ========================
# Coverage / Sonar / SonarQube
# ========================
coverage/
*.coverage
*.coveragexml
.sonarqube/
.scannerwork/

# ========================
# Azure / AWS credenciales
# ========================
.azure/
*.publishsettings
ServiceConfiguration.*.cscfg
